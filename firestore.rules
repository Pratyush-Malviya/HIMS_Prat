rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default-Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // global primitive validation helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "malviya.pratyush26@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Helper to validate Admin document shape
    function isValidAdmin(data) {
      return data.uid is string && data.uid.size() <= 128 
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 200
        && data.role is string && data.role.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 100
        && data.isPaid is bool
        && data.paymentPlan is string && data.paymentPlan.size() <= 100;
    }

    // Helper to validate Employee document shape
    function isValidEmployee(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.role is string && data.role.size() <= 100
        && data.department is string && data.department.size() <= 100
        && data.permittedModules is list && data.permittedModules.size() <= 20;
    }

    // Helper to validate ExpiredTrial document shape
    function isValidExpiredTrial(data) {
      return data.email is string && data.email.size() <= 200
        && data.expiredAt is string && data.expiredAt.size() <= 100;
    }

    // Helper to validate CustomRole document shape
    function isValidCustomRole(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.defaultDepartment is string && data.defaultDepartment.size() <= 200
        && data.defaultPermittedModules is list && data.defaultPermittedModules.size() <= 20;
    }

    // Admin Account operations
    match /admins/{adminId} {
      // Allow any signed-in user to get a specific admin document by direct ID (used on mount/lookup)
      allow get: if isSignedIn();
      
      // Restrict bulk listing to the owner or Super Admin
      allow list: if isSignedIn() && (request.auth.uid == adminId || request.auth.token.email == "malviya.pratyush26@gmail.com");
      
      // Allow creation during signup, bootstrapping the specified owner account
      allow create: if isSignedIn() && request.auth.uid == adminId && isValidAdmin(incoming());
      
      // Admins can update their own accounts, properties must match; or Super Admin can update
      allow update: if isSignedIn() && (
        (request.auth.uid == adminId && isValidAdmin(incoming())) ||
        (request.auth.token.email == "malviya.pratyush26@gmail.com" && isValidAdmin(incoming()))
      );
      
      // Only Super Admin can delete an admin record
      allow delete: if isSignedIn() && request.auth.token.email == "malviya.pratyush26@gmail.com" && request.auth.uid != adminId;
    }

    // Employee Account operational privileges (managed strictly by Admins)
    match /employees/{employeeId} {
      // Allow any signed-in workspace user to fetch a single employee by ID
      allow get: if isSignedIn();
      
      // Restrict bulk directory listing to Admins
      allow list: if isAdmin();
      
      allow create: if isAdmin() && isValidId(employeeId) && isValidEmployee(incoming()) && incoming().id == employeeId;
      
      allow update: if isAdmin() && isValidId(employeeId) && isValidEmployee(incoming()) && incoming().id == existing().id;
      
      allow delete: if isAdmin() && isValidId(employeeId);
    }

    // Custom Roles (managed strictly by Admins)
    match /custom_roles/{roleId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(roleId) && isValidCustomRole(incoming()) && incoming().id == roleId;
      allow update: if isAdmin() && isValidId(roleId) && isValidCustomRole(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin() && isValidId(roleId);
    }

    // Expired Trials Collection Tracker
    match /expired_trials/{emailId} {
      allow get: if true;
      allow list, write: if isSignedIn();
    }
  }
}
